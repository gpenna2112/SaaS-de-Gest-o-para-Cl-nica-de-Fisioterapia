# Copie para .env.local e preencha com valores reais. Nunca commitar .env.local.

NODE_ENV=development

# Usado por src/lib/env.ts e pelos repositórios/testes de integração.
DATABASE_URL=postgres://user:password@localhost:5432/clinic_management

# Opcional. Lido diretamente por src/lib/logger.ts, com default "info".
LOG_LEVEL=info

# Better Auth (ADR-0006/0017). Gere um valor com `openssl rand -base64 32`.
BETTER_AUTH_SECRET=troque-por-um-segredo-aleatorio-de-32-chars-ou-mais
BETTER_AUTH_URL=http://localhost:3000
