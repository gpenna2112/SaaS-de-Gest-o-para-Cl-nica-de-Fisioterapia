# Copie para .env.local e preencha com valores reais. Nunca commitar .env.local.

NODE_ENV=development

# Usado por src/lib/env.ts. Ainda não é consumido por nenhum código (src/db
# está deliberadamente vazio nesta etapa — ver src/db/README.md).
DATABASE_URL=postgres://user:password@localhost:5432/clinic_management

# Opcional. Lido diretamente por src/lib/logger.ts, com default "info".
LOG_LEVEL=info
